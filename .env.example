# URL pública do site (usada nas meta tags)
NEXT_PUBLIC_SITE_URL=https://seudominio.com.br

# Link do checkout (Kiwify, Hotmart, Yampi, etc.) — as UTMs da página são anexadas automaticamente
NEXT_PUBLIC_CHECKOUT_URL=https://pay.exemplo.com/antena-digital

# Número do WhatsApp com DDI e DDD, só dígitos (ex.: 5511999999999)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Google Analytics 4 (ex.: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Pixel Meta (ex.: 1234567890)
NEXT_PUBLIC_META_PIXEL_ID=

# Preços exibidos na oferta (apenas números)
NEXT_PUBLIC_PRICE_ORIGINAL=197
NEXT_PUBLIC_PRICE=97
